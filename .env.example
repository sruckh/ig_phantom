# =============================================================================
# IG Phantom — environment configuration (TEMPLATE)
# -----------------------------------------------------------------------------
# 1. Copy this file to .env:   cp .env.example .env
# 2. Fill in real values below.
# 3. NEVER commit .env  (it is gitignored; this template is safe to commit).
# =============================================================================

# --- Phantombuster (https://phantombuster.com) ---
# API key for your Phantombuster account.
PHANTOMBUSTER_API_KEY=your_phantombuster_api_key_here
# The ID of the Instagram scraper agent that n8n will launch.
AGENT_ID=your_agent_id_here

# --- Scraping options ---
# Number of posts to request per profile (default: 100).
POSTS_PER_PROFILE=100

# --- Server ---
# Port the Express server listens on INSIDE the container (default: 3000).
PORT=3000
# Public base URL where this server is reachable, so n8n can POST back to
# /api/scrape-complete. Leave empty to default to http://localhost:${PORT}.
# In production set this to your public origin, e.g. https://igphantom.example.com
CALLBACK_BASE_URL=
